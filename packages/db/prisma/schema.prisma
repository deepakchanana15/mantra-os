// MantraOS database schema
// Conventions: UUID PKs, soft deletes (deletedAt) on business entities,
// audit columns (createdAt/updatedAt/createdBy/updatedBy) on business entities,
// organizationId on every tenant-scoped table. See DATABASE.md for rationale.
//
// Append-only ledger tables (InventoryTransaction, AuditLog, GoodsReceipt) are
// deliberately NOT soft-deletable — corrections happen via offsetting entries,
// never by editing or deleting history. See DATABASE.md.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Identity domain — Organization, User, Membership, Role, Permission
// ─────────────────────────────────────────────────────────────────────────

model Organization {
  id        String    @id @default(uuid())
  name      String
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  memberships    Membership[]
  roles          Role[]
  settings       OrganizationSettings?
  deletionGrants UserDeletionGrant[]
  auditLogs      AuditLog[]

  companies Company[]
  countries Country[]
  brands    Brand[]
  websites  Website[]

  customers          Customer[]
  contacts           Contact[]
  categories         Category[]
  products           Product[]
  warehouses         Warehouse[]
  stockLevels        StockLevel[]
  inventoryTxns      InventoryTransaction[]
  quotes             Quote[]
  quoteLines         QuoteLine[]
  salesOrders        SalesOrder[]
  salesOrderLines    SalesOrderLine[]
  shipments          Shipment[]
  shipmentLines      ShipmentLine[]
  suppliers          Supplier[]
  purchaseOrders     PurchaseOrder[]
  purchaseOrderLines PurchaseOrderLine[]
  goodsReceipts      GoodsReceipt[]
  goodsReceiptLines  GoodsReceiptLine[]
  segments           Segment[]
  emailTemplates     EmailTemplate[]
  campaigns          Campaign[]
  notifications      Notification[]
  opportunities      Opportunity[]
  invoices           Invoice[]
  supportTickets     SupportTicket[]
  expenses           Expense[]
  attachments        Attachment[]
  supplierPhones     SupplierPhone[]

  @@map("organizations")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  name         String
  avatarUrl    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  memberships         Membership[]
  preferences         UserPreferences?
  grantsReceived      UserDeletionGrant[]  @relation("GrantReceivedBy")
  grantsIssued        UserDeletionGrant[]  @relation("GrantIssuedBy")
  auditLogs           AuditLog[]           @relation("AuditPerformedBy")
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

/// Never stores the raw token — only its SHA-256 hash, so a database leak
/// doesn't hand out usable reset links. The raw token exists only in the
/// emailed link and the requester's browser.
model PasswordResetToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("password_reset_tokens")
}

model Membership {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  roleId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])
  role         Role         @relation(fields: [roleId], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@map("memberships")
}

/// System roles have organizationId = null and are shared across every org.
/// Per-org custom roles (organizationId set) are a V2 capability — the shape
/// exists now so V2 doesn't need a schema rewrite, but V1 never creates one.
model Role {
  id             String   @id @default(uuid())
  organizationId String?
  key            String
  name           String
  isSystem       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization    Organization?    @relation(fields: [organizationId], references: [id])
  memberships     Membership[]
  rolePermissions RolePermission[]

  @@unique([organizationId, key])
  @@map("roles")
}

/// Global catalog, not tenant-scoped — the same permission keys apply to every org.
model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  resource    String
  action      String
  description String?

  rolePermissions RolePermission[]

  @@index([resource])
  @@map("permissions")
}

model RolePermission {
  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id])
  permission Permission @relation(fields: [permissionId], references: [id])

  @@id([roleId, permissionId])
  @@map("role_permissions")
}

// ─────────────────────────────────────────────────────────────────────────
// Deletion governance — see DECISIONS.md "Deletion governance"
// ─────────────────────────────────────────────────────────────────────────

/// Presence of a non-revoked row = this user may delete records in this org.
/// Owner needs no row — delete capability is implicit for Owner.
model UserDeletionGrant {
  id             String    @id @default(uuid())
  organizationId String
  userId         String
  grantedById    String
  grantedAt      DateTime  @default(now())
  revokedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation("GrantReceivedBy", fields: [userId], references: [id])
  grantedBy    User         @relation("GrantIssuedBy", fields: [grantedById], references: [id])

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@map("user_deletion_grants")
}

/// Append-only. Never updated or deleted — it is itself the audit trail.
model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  action         String
  entityType     String
  entityId       String
  performedById  String
  targetUserId   String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  performedBy  User         @relation("AuditPerformedBy", fields: [performedById], references: [id])

  @@index([organizationId, createdAt])
  @@index([performedById, createdAt])
  @@index([entityType, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────────────────
// Global domain — Company, Country, Brand, Website, Currency
// See DECISIONS.md "Global multi-country, multi-company, multi-brand
// architecture" for the full design rationale. Chain: Organization (still
// the RLS tenant boundary, unchanged) -> Company -> Country -> Warehouse,
// with Brand and Website attached at the Organization/Country level.
// Sub-phase A: master data only. Scoping existing entities to
// Company/Country/Brand is Sub-phase B.
// ─────────────────────────────────────────────────────────────────────────

/// Global reference data (ISO 4217), not tenant-scoped — a currency code
/// means the same thing for every organization. Historical exchange-rate
/// tracking and transaction-level currency conversion are a follow-on phase.
model Currency {
  id            String   @id @default(uuid())
  code          String   @unique
  name          String
  symbol        String
  decimalPlaces Int      @default(2)
  enabled       Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  companies Company[]
  countries Country[]
  websites  Website[]

  @@map("currencies")
}

/// A legal entity within an Organization (Mantra Sports Australia Pty Ltd,
/// Mantra Sports USA LLC, ...). Organization stays the RLS tenant boundary;
/// Company is a new sub-entity layer beneath it, not a replacement for it.
model Company {
  id                 String    @id @default(uuid())
  organizationId     String
  name               String
  legalName          String?
  registrationNumber String?
  baseCurrencyId     String?
  enabled            Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  createdBy          String
  updatedBy          String
  deletedAt          DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id])
  baseCurrency   Currency?       @relation(fields: [baseCurrencyId], references: [id])
  countries      Country[]
  customers      Customer[]
  quotes         Quote[]
  salesOrders    SalesOrder[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  opportunities  Opportunity[]
  invoices       Invoice[]
  supportTickets SupportTicket[]
  expenses       Expense[]

  @@index([organizationId])
  @@map("companies")
}

/// Belongs to a Company, not directly to Organization (confirmed by the
/// requirement itself: "Warehouse belongs to a country. Country belongs to
/// a company."). organizationId is denormalized here too, matching this
/// project's existing convention on line-item tables — RLS policies stay a
/// simple column comparison instead of a subquery through Company.
model Country {
  id              String    @id @default(uuid())
  organizationId  String
  companyId       String
  name            String
  isoCode         String
  currencyId      String?
  defaultLanguage String?
  timeZone        String?
  dateFormat      String?
  /// Simple flat rate for V1 — see DECISIONS.md "Tax and pricing, framework
  /// not data". The full multi-rule tax engine (GST/VAT/CGST/SGST/IGST,
  /// dated, compound) is a follow-on phase once real rates exist to build
  /// and test against.
  taxPercentage   Decimal?  @db.Decimal(5, 2)
  enabled         Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String
  updatedBy       String
  deletedAt       DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id])
  company        Company         @relation(fields: [companyId], references: [id])
  currency       Currency?       @relation(fields: [currencyId], references: [id])
  warehouses     Warehouse[]
  websites       Website[]
  customers      Customer[]
  quotes         Quote[]
  salesOrders    SalesOrder[]
  suppliers      Supplier[]
  purchaseOrders PurchaseOrder[]
  opportunities  Opportunity[]
  invoices       Invoice[]
  supportTickets SupportTicket[]
  expenses       Expense[]

  @@unique([companyId, isoCode])
  @@index([organizationId])
  @@index([companyId])
  @@map("countries")
}

/// Cross-cutting, not tied to one Company — belongs to the Organization
/// directly. Product/Campaign get brandId in Sub-phase B.
model Brand {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  slug           String
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  websites     Website[]
  products     Product[]
  campaigns    Campaign[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@map("brands")
}

model Website {
  id             String    @id @default(uuid())
  organizationId String
  countryId      String
  brandId        String
  currencyId     String?
  language       String?
  shopifyStoreId String?
  domain         String?
  enabled        Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  country      Country      @relation(fields: [countryId], references: [id])
  brand        Brand        @relation(fields: [brandId], references: [id])
  currency     Currency?    @relation(fields: [currencyId], references: [id])

  @@index([organizationId])
  @@index([countryId])
  @@index([brandId])
  @@map("websites")
}

// ─────────────────────────────────────────────────────────────────────────
// CRM domain
// ─────────────────────────────────────────────────────────────────────────

// Sports-business customer taxonomy — see DECISIONS.md "Customer type
// taxonomy" for the full list's source and the labels/descriptions shown in
// the UI (kept in apps/web/lib/customer-types.ts, not duplicated here).
enum CustomerType {
  USER
  STORE
  ACADEMY
  CLUB
  COACH
  PROFESSIONAL
  SCHOOL
  COLLEGE_UNIVERSITY
  ASSOCIATION
  CORPORATE
  GOVERNMENT
  TEAM
  DISTRIBUTOR
  DEALER
  FRANCHISE
  EVENT_ORGANIZER
  RENTAL_PROVIDER
  NGO_FOUNDATION
  INFLUENCER_CREATOR
  OEM_PRIVATE_LABEL
}

model Customer {
  id              String       @id @default(uuid())
  organizationId  String
  /// Nullable — see DECISIONS.md "Global multi-country, multi-company,
  /// multi-brand architecture" Sub-phase B: existing records predate this
  /// scoping and aren't backfilled, set going forward.
  companyId       String?
  countryId       String?
  name            String
  type            CustomerType @default(USER)
  email           String?
  phone           String?
  billingAddress  Json?
  shippingAddress Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt
  createdBy       String
  updatedBy       String
  deletedAt       DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id])
  company        Company?        @relation(fields: [companyId], references: [id])
  country        Country?        @relation(fields: [countryId], references: [id])
  contacts       Contact[]
  quotes         Quote[]
  salesOrders    SalesOrder[]
  opportunities  Opportunity[]
  invoices       Invoice[]
  supportTickets SupportTicket[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([companyId])
  @@index([countryId])
  @@map("customers")
}

model Contact {
  id             String    @id @default(uuid())
  organizationId String
  customerId     String
  name           String
  email          String?
  phone          String?
  role           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@index([organizationId])
  @@index([customerId])
  @@map("contacts")
}

// ─────────────────────────────────────────────────────────────────────────
// Products domain
// ─────────────────────────────────────────────────────────────────────────

model Category {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  parentId       String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  parent       Category?    @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children     Category[]   @relation("CategoryHierarchy")
  products     Product[]

  @@index([organizationId])
  @@index([parentId])
  @@map("categories")
}

model Product {
  id             String    @id @default(uuid())
  organizationId String
  categoryId     String?
  /// Nullable — see DECISIONS.md Sub-phase B.
  brandId        String?
  sku            String
  name           String
  description    String?
  unitPrice      Decimal   @db.Decimal(12, 2)
  unitCost       Decimal?  @db.Decimal(12, 2)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization          Organization           @relation(fields: [organizationId], references: [id])
  category              Category?              @relation(fields: [categoryId], references: [id])
  brand                 Brand?                 @relation(fields: [brandId], references: [id])
  stockLevels           StockLevel[]
  inventoryTransactions InventoryTransaction[]
  quoteLines            QuoteLine[]
  salesOrderLines       SalesOrderLine[]
  purchaseOrderLines    PurchaseOrderLine[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([categoryId])
  @@index([brandId])
  @@map("products")
}

// ─────────────────────────────────────────────────────────────────────────
// Inventory domain
// ─────────────────────────────────────────────────────────────────────────

model Warehouse {
  id             String    @id @default(uuid())
  organizationId String
  /// Nullable: existing warehouses predate the multi-country model and
  /// aren't assigned a country by the Sub-phase A migration — set going
  /// forward, backfilled for existing rows as a separate data task.
  countryId      String?
  name           String
  address        Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization          Organization           @relation(fields: [organizationId], references: [id])
  country               Country?               @relation(fields: [countryId], references: [id])
  stockLevels           StockLevel[]
  inventoryTransactions InventoryTransaction[]
  shipments             Shipment[]
  goodsReceipts         GoodsReceipt[]

  @@index([organizationId])
  @@index([countryId])
  @@map("warehouses")
}

/// Current-state snapshot, derived from InventoryTransaction history.
/// One row per product x warehouse — updated on every transaction, never
/// the source of truth by itself (InventoryTransaction is).
model StockLevel {
  id               String   @id @default(uuid())
  organizationId   String
  productId        String
  warehouseId      String
  quantityOnHand   Int      @default(0)
  quantityReserved Int      @default(0)
  reorderPoint     Int?
  updatedAt        DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])

  @@unique([productId, warehouseId])
  @@index([organizationId])
  @@map("stock_levels")
}

enum InventoryTransactionType {
  RECEIPT
  SHIPMENT
  ADJUSTMENT
  TRANSFER_IN
  TRANSFER_OUT
}

/// Append-only ledger — the 10M-row scale target. Never updated or soft-deleted;
/// corrections are new offsetting ADJUSTMENT rows, never edits to history.
/// See DATABASE.md for the indexing rationale behind the composite index below.
model InventoryTransaction {
  id             String                   @id @default(uuid())
  organizationId String
  productId      String
  warehouseId    String
  type           InventoryTransactionType
  quantity       Int
  referenceType  String?
  referenceId    String?
  createdAt      DateTime                 @default(now())
  createdBy      String

  organization Organization @relation(fields: [organizationId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])
  warehouse    Warehouse    @relation(fields: [warehouseId], references: [id])

  @@index([organizationId, warehouseId, productId, createdAt])
  @@index([organizationId, createdAt])
  @@index([referenceType, referenceId])
  @@map("inventory_transactions")
}

// ─────────────────────────────────────────────────────────────────────────
// Sales domain
// ─────────────────────────────────────────────────────────────────────────

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

model Quote {
  id             String      @id @default(uuid())
  organizationId String
  /// Nullable — see DECISIONS.md Sub-phase B.
  companyId      String?
  countryId      String?
  customerId     String
  status         QuoteStatus @default(DRAFT)
  validUntil     DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  country      Country?     @relation(fields: [countryId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  lines        QuoteLine[]
  salesOrder   SalesOrder?

  @@index([organizationId])
  @@index([customerId])
  @@index([companyId])
  @@index([countryId])
  @@map("quotes")
}

model QuoteLine {
  id             String  @id @default(uuid())
  organizationId String
  quoteId        String
  productId      String
  quantity       Int
  unitPrice      Decimal @db.Decimal(12, 2)

  organization Organization @relation(fields: [organizationId], references: [id])
  quote        Quote        @relation(fields: [quoteId], references: [id])
  product      Product      @relation(fields: [productId], references: [id])

  @@index([organizationId])
  @@index([quoteId])
  @@map("quote_lines")
}

enum SalesOrderStatus {
  PENDING
  CONFIRMED
  PARTIALLY_SHIPPED
  SHIPPED
  CANCELLED
}

enum SalesChannel {
  ONLINE
  OFFLINE
}

enum OnlineChannelType {
  WEBSITE_STORE
  MARKETPLACE
}

enum OfflineChannelType {
  WALK_IN
  PHONE_ORDER
  WHATSAPP
  EMAIL
  SALES_REPRESENTATIVE
  DISTRIBUTOR_DEALER
  EXHIBITION_TOURNAMENT
}

model SalesOrder {
  id                 String              @id @default(uuid())
  organizationId     String
  /// Nullable — see DECISIONS.md Sub-phase B.
  companyId          String?
  countryId          String?
  customerId         String
  quoteId            String?             @unique
  status             SalesOrderStatus    @default(PENDING)
  orderDate          DateTime            @default(now())
  /// Nullable at the DB level (existing rows predate this field, not
  /// backfilled) but required by CreateSalesOrderDto going forward — see
  /// DECISIONS.md "Sales channel tracking".
  salesChannel       SalesChannel?
  onlineChannelType  OnlineChannelType?
  offlineChannelType OfflineChannelType?
  orderReference     String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdBy          String
  updatedBy          String
  deletedAt          DateTime?

  organization Organization     @relation(fields: [organizationId], references: [id])
  company      Company?         @relation(fields: [companyId], references: [id])
  country      Country?         @relation(fields: [countryId], references: [id])
  customer     Customer         @relation(fields: [customerId], references: [id])
  quote        Quote?           @relation(fields: [quoteId], references: [id])
  lines        SalesOrderLine[]
  shipments    Shipment[]
  invoices     Invoice[]

  @@index([organizationId])
  @@index([customerId])
  @@index([companyId])
  @@index([countryId])
  @@index([salesChannel])
  @@map("sales_orders")
}

model SalesOrderLine {
  id             String  @id @default(uuid())
  organizationId String
  salesOrderId   String
  productId      String
  quantity       Int
  unitPrice      Decimal @db.Decimal(12, 2)

  organization  Organization   @relation(fields: [organizationId], references: [id])
  salesOrder    SalesOrder     @relation(fields: [salesOrderId], references: [id])
  product       Product        @relation(fields: [productId], references: [id])
  shipmentLines ShipmentLine[]

  @@index([organizationId])
  @@index([salesOrderId])
  @@map("sales_order_lines")
}

enum ShipmentStatus {
  PENDING
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

model Shipment {
  id             String         @id @default(uuid())
  organizationId String
  salesOrderId   String
  warehouseId    String
  status         ShipmentStatus @default(PENDING)
  trackingNumber String?
  shippedAt      DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization Organization   @relation(fields: [organizationId], references: [id])
  salesOrder   SalesOrder     @relation(fields: [salesOrderId], references: [id])
  warehouse    Warehouse      @relation(fields: [warehouseId], references: [id])
  lines        ShipmentLine[]

  @@index([organizationId])
  @@index([salesOrderId])
  @@map("shipments")
}

model ShipmentLine {
  id               String @id @default(uuid())
  organizationId   String
  shipmentId       String
  salesOrderLineId String
  quantity         Int

  organization   Organization   @relation(fields: [organizationId], references: [id])
  shipment       Shipment       @relation(fields: [shipmentId], references: [id])
  salesOrderLine SalesOrderLine @relation(fields: [salesOrderLineId], references: [id])

  @@index([organizationId])
  @@index([shipmentId])
  @@map("shipment_lines")
}

// ─────────────────────────────────────────────────────────────────────────
// Purchasing domain
// ─────────────────────────────────────────────────────────────────────────

model Supplier {
  id             String    @id @default(uuid())
  organizationId String
  /// Nullable — see DECISIONS.md Sub-phase B.
  companyId      String?
  countryId      String?
  name           String
  email          String?
  phone          String?
  address        Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization   Organization    @relation(fields: [organizationId], references: [id])
  company        Company?        @relation(fields: [companyId], references: [id])
  country        Country?        @relation(fields: [countryId], references: [id])
  purchaseOrders PurchaseOrder[]
  expenses       Expense[]
  phones         SupplierPhone[]

  @@index([organizationId])
  @@index([companyId])
  @@index([countryId])
  @@map("suppliers")
}

/// Free-text label (not an enum) — "mobile, office, WhatsApp, etc." is
/// explicitly open-ended, so a fixed enum would need a migration every
/// time a new label shows up. organizationId denormalized here, matching
/// this project's line-item-table convention (see Country's own comment).
model SupplierPhone {
  id             String  @id @default(uuid())
  organizationId String
  supplierId     String
  label          String
  number         String
  isPrimary      Boolean @default(false)

  organization Organization @relation(fields: [organizationId], references: [id])
  supplier     Supplier     @relation(fields: [supplierId], references: [id])

  @@index([organizationId])
  @@index([supplierId])
  @@map("supplier_phones")
}

enum PurchaseOrderStatus {
  DRAFT
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrder {
  id             String              @id @default(uuid())
  organizationId String
  /// Nullable — see DECISIONS.md Sub-phase B.
  companyId      String?
  countryId      String?
  supplierId     String
  status         PurchaseOrderStatus @default(DRAFT)
  orderDate      DateTime            @default(now())
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization  Organization        @relation(fields: [organizationId], references: [id])
  company       Company?            @relation(fields: [companyId], references: [id])
  country       Country?            @relation(fields: [countryId], references: [id])
  supplier      Supplier            @relation(fields: [supplierId], references: [id])
  lines         PurchaseOrderLine[]
  goodsReceipts GoodsReceipt[]
  expenses      Expense[]

  @@index([organizationId])
  @@index([supplierId])
  @@index([companyId])
  @@index([countryId])
  @@map("purchase_orders")
}

model PurchaseOrderLine {
  id              String  @id @default(uuid())
  organizationId  String
  purchaseOrderId String
  productId       String
  quantity        Int
  unitCost        Decimal @db.Decimal(12, 2)

  organization      Organization       @relation(fields: [organizationId], references: [id])
  purchaseOrder     PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  product           Product            @relation(fields: [productId], references: [id])
  goodsReceiptLines GoodsReceiptLine[]

  @@index([organizationId])
  @@index([purchaseOrderId])
  @@map("purchase_order_lines")
}

/// Append-only — a receipt event, not a mutable record. Feeds InventoryTransaction.
model GoodsReceipt {
  id              String   @id @default(uuid())
  organizationId  String
  purchaseOrderId String
  warehouseId     String
  receivedAt      DateTime @default(now())
  createdBy       String

  organization  Organization       @relation(fields: [organizationId], references: [id])
  purchaseOrder PurchaseOrder      @relation(fields: [purchaseOrderId], references: [id])
  warehouse     Warehouse          @relation(fields: [warehouseId], references: [id])
  lines         GoodsReceiptLine[]
  expenses      Expense[]

  @@index([organizationId])
  @@index([purchaseOrderId])
  @@map("goods_receipts")
}

/// Append-only, like its parent GoodsReceipt — see DATABASE.md "Append-only ledger tables".
model GoodsReceiptLine {
  id                  String @id @default(uuid())
  organizationId      String
  goodsReceiptId      String
  purchaseOrderLineId String
  quantity            Int

  organization      Organization      @relation(fields: [organizationId], references: [id])
  goodsReceipt      GoodsReceipt      @relation(fields: [goodsReceiptId], references: [id])
  purchaseOrderLine PurchaseOrderLine @relation(fields: [purchaseOrderLineId], references: [id])

  @@index([organizationId])
  @@index([goodsReceiptId])
  @@map("goods_receipt_lines")
}

enum ExpenseCategory {
  GOODS_RECEIPT
  RENT
  UTILITIES
  SALARIES
  SHIPPING
  MARKETING
  OFFICE_SUPPLIES
  PROFESSIONAL_SERVICES
  OTHER
}

/// Minimal expense tracking — see DECISIONS.md "Goods receipt upload +
/// Expense". Usually created alongside a GoodsReceipt (vendor hard-copy
/// receipt uploaded, amount auto-calculated from received line costs,
/// reviewed before saving), but stands alone so non-goods expenses (rent,
/// software) can use the same entity later.
model Expense {
  id              String          @id @default(uuid())
  organizationId  String
  companyId       String?
  countryId       String?
  supplierId      String?
  goodsReceiptId  String?
  purchaseOrderId String?
  vendorName      String
  category        ExpenseCategory @default(OTHER)
  amount          Decimal         @db.Decimal(12, 2)
  expenseDate     DateTime        @default(now())
  notes           String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  createdBy       String
  updatedBy       String
  deletedAt       DateTime?

  organization  Organization   @relation(fields: [organizationId], references: [id])
  company       Company?       @relation(fields: [companyId], references: [id])
  country       Country?       @relation(fields: [countryId], references: [id])
  supplier      Supplier?      @relation(fields: [supplierId], references: [id])
  goodsReceipt  GoodsReceipt?  @relation(fields: [goodsReceiptId], references: [id])
  purchaseOrder PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])

  @@index([organizationId])
  @@index([supplierId])
  @@index([goodsReceiptId])
  @@index([purchaseOrderId])
  @@index([companyId])
  @@index([countryId])
  @@map("expenses")
}

enum AttachmentEntityType {
  GOODS_RECEIPT
  EXPENSE
}

/// Polymorphic — entityType + entityId, no foreign key (same pattern as
/// AuditLog) since it references whichever table entityType names. One or
/// more per record (supplier invoice, delivery challan, packing slip, GRN
/// copy, ...) — see DECISIONS.md "Multi-document attachments".
model Attachment {
  id             String               @id @default(uuid())
  organizationId String
  entityType     AttachmentEntityType
  entityId       String
  fileUrl        String
  fileName       String
  contentType    String?
  createdAt      DateTime             @default(now())
  createdBy      String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([entityType, entityId])
  @@map("attachments")
}

// ─────────────────────────────────────────────────────────────────────────
// Marketing domain — email campaigns to CRM segments (see DECISIONS.md)
// ─────────────────────────────────────────────────────────────────────────

model Segment {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  filterJson     Json
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  campaigns    Campaign[]

  @@index([organizationId])
  @@map("segments")
}

model EmailTemplate {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  subject        String
  bodyHtml       String
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  campaigns    Campaign[]

  @@index([organizationId])
  @@map("email_templates")
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  CANCELLED
}

model Campaign {
  id             String         @id @default(uuid())
  organizationId String
  /// Nullable — see DECISIONS.md Sub-phase B.
  brandId        String?
  segmentId      String
  templateId     String
  status         CampaignStatus @default(DRAFT)
  scheduledAt    DateTime?
  sentAt         DateTime?
  stats          Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id])
  brand        Brand?        @relation(fields: [brandId], references: [id])
  segment      Segment       @relation(fields: [segmentId], references: [id])
  template     EmailTemplate @relation(fields: [templateId], references: [id])

  @@index([organizationId])
  @@index([brandId])
  @@map("campaigns")
}

// ─────────────────────────────────────────────────────────────────────────
// Sales pipeline & billing domain (Sub-phase C — see DECISIONS.md "Global
// multi-country, multi-company, multi-brand architecture")
// ─────────────────────────────────────────────────────────────────────────

enum OpportunityStage {
  NEW
  QUALIFIED
  PROPOSAL
  NEGOTIATION
  WON
  LOST
}

/// Pre-Quote sales pipeline stage — minimal version, not yet linked to Quote.
model Opportunity {
  id                String           @id @default(uuid())
  organizationId    String
  companyId         String?
  countryId         String?
  customerId        String
  name              String
  stage             OpportunityStage @default(NEW)
  estimatedValue    Decimal?         @db.Decimal(12, 2)
  expectedCloseDate DateTime?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  createdBy         String
  updatedBy         String
  deletedAt         DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  country      Country?     @relation(fields: [countryId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@index([organizationId])
  @@index([customerId])
  @@index([companyId])
  @@index([countryId])
  @@map("opportunities")
}

enum InvoiceStatus {
  DRAFT
  SENT
  PAID
  OVERDUE
  VOID
}

/// Minimal version — a single amount, not itemized lines. Optionally tied
/// to a SalesOrder; standalone invoices are also allowed.
model Invoice {
  id             String        @id @default(uuid())
  organizationId String
  companyId      String?
  countryId      String?
  customerId     String
  salesOrderId   String?
  invoiceNumber  String
  status         InvoiceStatus @default(DRAFT)
  amount         Decimal       @db.Decimal(12, 2)
  issuedAt       DateTime?
  dueDate        DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  country      Country?     @relation(fields: [countryId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])
  salesOrder   SalesOrder?  @relation(fields: [salesOrderId], references: [id])

  @@unique([organizationId, invoiceNumber])
  @@index([organizationId])
  @@index([customerId])
  @@index([salesOrderId])
  @@index([companyId])
  @@index([countryId])
  @@map("invoices")
}

// ─────────────────────────────────────────────────────────────────────────
// Support domain (Sub-phase C)
// ─────────────────────────────────────────────────────────────────────────

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model SupportTicket {
  id             String                @id @default(uuid())
  organizationId String
  companyId      String?
  countryId      String?
  customerId     String
  subject        String
  description    String?
  status         SupportTicketStatus   @default(OPEN)
  priority       SupportTicketPriority @default(MEDIUM)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  createdBy      String
  updatedBy      String
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id])
  company      Company?     @relation(fields: [companyId], references: [id])
  country      Country?     @relation(fields: [countryId], references: [id])
  customer     Customer     @relation(fields: [customerId], references: [id])

  @@index([organizationId])
  @@index([customerId])
  @@index([companyId])
  @@index([countryId])
  @@map("support_tickets")
}

// ─────────────────────────────────────────────────────────────────────────
// Notifications domain
// ─────────────────────────────────────────────────────────────────────────

model Notification {
  id             String    @id @default(uuid())
  organizationId String
  userId         String
  type           String
  title          String
  body           String?
  metadata       Json?
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  organization Organization @relation(fields: [organizationId], references: [id])
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId, userId, createdAt])
  @@index([userId, readAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────────────────
// Settings domain
// ─────────────────────────────────────────────────────────────────────────

model OrganizationSettings {
  organizationId String   @id
  timezone       String   @default("UTC")
  currency       String   @default("USD")
  dateFormat     String   @default("YYYY-MM-DD")
  updatedAt      DateTime @updatedAt
  updatedBy      String

  organization Organization @relation(fields: [organizationId], references: [id])

  @@map("organization_settings")
}

model UserPreferences {
  userId    String   @id
  theme     String   @default("system")
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_preferences")
}
